# Integration Configuration - LLM + Serverless Development Environment

# ====================================
# LLM Configuration
# ====================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus

# OpenAI API (alternative)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4

# Google Gemini API (alternative)
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-pro

# ====================================
# LLM Behavior Configuration
# ====================================

# Temperature for LLM responses (0-1, higher = more creative)
LLM_TEMPERATURE=0.7

# Enable streaming for large responses
LLM_STREAMING=false

# ====================================
# Serverless Simulator Configuration
# ====================================

# Port for simulator API server
SIMULATOR_PORT=4000

# Enable debug logging
SIMULATOR_DEBUG=false

# Enable hot reload for schema changes
SIMULATOR_HOT_RELOAD=true

# Enable persistence of simulator state
SIMULATOR_PERSISTENCE=false

# ====================================
# React App Configuration
# ====================================

# For React applications (create-react-app, Vite, etc)
REACT_APP_ANTHROPIC_KEY=your_anthropic_api_key_here
REACT_APP_LLM_PROVIDER=anthropic

# ====================================
# Database Integration (Optional)
# ====================================

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ====================================
# Logging & Debugging
# ====================================

# Debug logging level: debug, info, warn, error
DEBUG_LEVEL=info

# Log to file
LOG_FILE_PATH=./logs/integration.log

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=false
